{
    "compilerOptions": {
        "outDir": "./dist/",
        "module": "commonjs",
        "target": "es2015",
        "jsx": "react",
        "allowJs": true,
        "baseUrl": ".",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "node",
        "strict": true,
        "skipLibCheck": true,
        "types": ["node", "jest"],
        "ignoreDeprecations": "6.0"
    }
}
