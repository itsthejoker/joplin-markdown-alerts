{
    "manifest_version": 1,
    "id": "com.bwat47.joplin-markdown-alerts",
    "app_min_version": "3.3",
    "version": "1.3.1",
    "platforms": ["desktop", "mobile"],
    "name": "Markdown Alerts and Quotes",
    "description": "Add support for GitHub-style alerts (callouts) in the markdown editor/viewer, plus editor commands for alerts and blockquotes.",
    "author": "bwat47",
    "homepage_url": "https://github.com/bwat47/joplin-markdown-alerts",
    "repository_url": "https://github.com/bwat47/joplin-markdown-alerts",
